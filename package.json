{
  "name": "lymo-browser",
  "version": "1.0.8",
  "description": "Simple Electron browser",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.lymo.browser",
    "productName": "Lymo",
    "artifactName": "LymoBrowserSetup.exe",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lymo"
    },
    "publish": {
      "provider": "github",
      "owner": "lymodevofc",
      "repo": "lymo-browser",
      "releaseType": "release"
    }
  }
}
